    {
        "id": "prepare_qdrant",
        "type": "function",
        "z": "8e4023b8523e3808",
        "name": "Przygotuj Paczkę (Qdrant)",
        "func": "// Pobieramy wygenerowany wektor z odpowiedzi Ollamy\nlet vector = msg.payload.embedding;\n\n// Prosty generator unikalnego ID (UUID) dla punktu w bazie wektorowej\nfunction uuidv4() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\n    var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);\n    return v.toString(16);\n  });\n}\n\n// Budujemy ostateczny payload dla bazy Qdrant\nmsg.payload = {\n    \"points\": [\n        {\n            \"id\": uuidv4(),\n            \"vector\": vector,\n            \"payload\": msg.airly_metadata // Zapisujemy oryginalny JSON jako metadane!\n        }\n    ]\n};\n\nreturn msg;",
        "outputs": 1,
        "x": 990,
        "y": 920,
        "wires": [
            [
                "call_qdrant"
            ]
        ]
    },
