    {
        "id": "parser_node",
        "type": "function",
        "z": "8e4023b8523e3808",
        "name": "Parser: Airly -> SQL/Rabbit",
        "func": "if (!msg.payload || !msg.payload.current) return null;\n\nlet current = msg.payload.current.values;\nlet forecast = msg.payload.forecast || [];\nlet stationId = msg.station_id || \"unknown\";\nlet timestamp = msg.payload.current.tillDateTime;\n\n// Wyciąganie bieżących wartości\nlet data = {};\ncurrent.forEach(v => {\n    data[v.name] = v.value;\n});\n\n// --- WYJŚCIE 1: Dla PostgreSQL (Tylko czyste fakty, bez prognoz) ---\nlet msgSQL = {\n    query: \"INSERT INTO airly_readings (station_id, measurement_time, pm1, pm25, pm10, temperature, humidity) VALUES ($1, $2, $3, $4, $5, $6, $7);\",\n    params: [\n        stationId,\n        timestamp,\n        data[\"PM1\"] || null,\n        data[\"PM25\"] || null,\n        data[\"PM10\"] || null,\n        data[\"TEMPERATURE\"] || null,\n        data[\"HUMIDITY\"] || null\n    ]\n};\n\n// --- WYJŚCIE 2: Dla RabbitMQ (Pełen kontekst dla systemu RAG) ---\nlet msgRabbit = {\n    payload: {\n        station: stationId,\n        time: timestamp,\n        current_values: data,    \n        forecast: forecast      \n    },\n    routingKey: \"telemetry.airly.station_\" + stationId\n};\n\nreturn [msgSQL, msgRabbit];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1020,
        "y": 700,
        "wires": [
            [
                "postgres_node"
            ],
            [
                "rabbit_node"
            ]
        ]
    },
