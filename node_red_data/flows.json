    {
        "id": "prepare_ollama",
        "type": "function",
        "z": "8e4023b8523e3808",
        "name": "Przygotuj Tekst dla AI",
        "func": "// Upewniamy się, że payload to obiekt\nlet data = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload;\n\n// Tworzymy opis tekstowy dla modelu AI (to ten tekst zostanie zamieniony na wektor!)\nlet vals = data.current_values || {};\nlet textPrompt = `Pomiar jakości powietrza. Stacja: ${data.station}, Czas: ${data.time}. ` +\n                 `PM10 wynosi ${vals.PM10 || 'brak'}, PM2.5 wynosi ${vals.PM25 || 'brak'}, ` +\n                 `Temperatura to ${vals.TEMPERATURE || 'brak'}°C.`;\n\n// Zapisujemy oryginalne dane z Airly (w tym prognozy) na boku, aby ich nie stracić\nmsg.airly_metadata = data;\n\n// Ustawiamy payload dla zapytania do Ollamy\nmsg.payload = {\n    \"model\": \"nomic-embed-text\",\n    \"prompt\": textPrompt\n};\n\nreturn msg;",
        "outputs": 1,
        "x": 540,
        "y": 920,
        "wires": [
            [
                "call_ollama"
            ]
        ]
    },
