# 1. Ignore environment variables (Security)
.env

# 2. Ignore Database & AI Volumes (Massive binaries and data)
postgres_data/
qdrant_data/
ollama_data/
rabbitmq_data/

# 3. Ignore Node-RED local data folder (Keep flows, ignore modules/credentials)
node_red_data/node_modules/
node_red_data/.sessions.json
node_red_data/.config.*
node_red_data/.npm/*
node_red_data/package-lock.json
node_red_data/.flows*
node_red_data/flows_cred.json
node_red_data/lib/

# 4. General OS and IDE generated files (Best practice)
.DS_Store
Thumbs.db
.vscode/
.idea/
